---
// Full-screen loading overlay. Counter 0→100 then slides up.
// One-shot per session (sessionStorage "seen" flag). Driven by preloader.js.
---

<div id="preloader" class="preloader" role="status" aria-label="Loading">
  <span class="preloader__count" aria-hidden="true">000</span>
</div>

<style lang="scss">
.preloader {
  position: fixed;
  inset: 0;
  z-index: var(--z-preloader);
  background-color: var(--color-bg);
  display: flex;
  align-items: flex-end;
  padding: var(--space-6) var(--grid-margin);
  pointer-events: none;  /* page beneath stays interactive if JS stalls */

  &__count {
    font-size: var(--text-4xl);
    font-weight: 500;
    color: var(--color-fg);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
}
</style>
