---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Cursor from '../components/layout/Cursor.astro';
import Preloader from '../components/motion/Preloader.astro';
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio',
  description = 'Creative developer portfolio',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="page">
    <Preloader />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Cursor />

    <script>
      import { initLenis, destroyLenis } from '../scripts/lenis.js';
      import { initCursor, destroyCursor } from '../scripts/cursor.js';
      import { initPreloader } from '../scripts/preloader.js';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      function init() {
        initLenis();
        initCursor();
        ScrollTrigger.refresh();
      }

      function cleanup() {
        destroyLenis();
        destroyCursor();
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      // First load: preloader paints first, Lenis + cursor mount only after
      // the overlay exits. On repeat visits onDone fires synchronously.
      initPreloader(() => init());

      // Page transitions: preloader is already done (session flag), so init
      // runs immediately on swap without waiting for any animation.
      document.addEventListener('astro:before-preparation', cleanup);
      document.addEventListener('astro:after-swap', init);
    </script>
  </body>
</html>
