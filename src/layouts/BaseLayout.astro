---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Cursor from '../components/layout/Cursor.astro';
import Preloader from '../components/motion/Preloader.astro';
import PageTransition from '../components/motion/PageTransition.astro';
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'SP — Creative Developer',
  description = 'Creative developer building high-craft digital experiences at the intersection of design and engineering.',
  ogImage = '/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical + OG -->
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta name="twitter:card"       content="summary_large_image" />
    <meta name="twitter:title"      content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"      content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: DM Sans variable — preconnect first, then load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..900;1,9..40,100..900&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="page">
    <Preloader />
    <PageTransition />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Cursor />

    <script>
      import { initLenis, destroyLenis } from '../scripts/lenis.js';
      import { initCursor, destroyCursor } from '../scripts/cursor.js';
      import { initPreloader } from '../scripts/preloader.js';
      import { playTransitionIn, playTransitionOut } from '../scripts/transitions.js';
      import { initSplitText, destroySplitText } from '../scripts/splitText.js';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      function init() {
        initLenis();
        initCursor();
        ScrollTrigger.refresh();
        initSplitText();
        // Pages with per-page animations listen for this event.
        document.dispatchEvent(new CustomEvent('portfolio:init'));
      }

      function cleanup() {
        destroyLenis();
        destroyCursor();
        destroySplitText();
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      // First load: preloader paints first, Lenis + cursor mount only after
      // the overlay exits. On repeat visits onDone fires synchronously.
      initPreloader(() => init());

      // Navigation: play transition in (parallel with Astro's page fetch).
      // event.intercept ensures the DOM swap is held until the overlay covers.
      document.addEventListener('astro:before-preparation', (event) => {
        cleanup();
        event.intercept({ handler: () => playTransitionIn() });
      });

      // After swap: reveal new page + re-init.
      document.addEventListener('astro:after-swap', () => {
        init();
        playTransitionOut();
      });
    </script>
  </body>
</html>
